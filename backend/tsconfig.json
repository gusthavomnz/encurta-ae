{
  "compilerOptions": {
    "module": "CommonJS",                  // Padrão mais compatível com Node.js tradicional
    "target": "ES2022",                    // Garante suporte a async/await modernos
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "esModuleInterop": true,               // Permite misturar import e require sem dar erro
    "allowSyntheticDefaultImports": true,  // Ajuda na compatibilidade de libs antigas
    "strict": false,                        // Desativa a rigidez extrema temporariamente para sumir os erros
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}